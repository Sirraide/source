// R      %srcc --ir   --target x86_64-unknown-linux -I test/inputs %s
// R[//L] %srcc --llvm --target x86_64-unknown-linux -I test/inputs %s
program test;

import <opaque.hh> as *;

// Check that we don't attempt to add 'dereferenceable' attributes to
// pointers to opaque type (this would require knowing the size of the
// pointee type, which isn't possible for opaque types and would crash).

proc f(OpaqueType^) {}


// R      %srcc --ir   --target x86_64-unknown-linux %s
// R[//L] %srcc --llvm --target x86_64-unknown-linux %s
program test;

struct Small {
    int x;
    delete { }
};

proc f1 {
    var s = Small(42);
    delete s;
    s = Small(45);
    delete s;
}

proc f2 (bool x) {
    var s = Small(42);
    if x {
        delete s;
    } else {
        delete s;
    }
}

proc f3 (bool x) {
    var s = Small(42);
    if x delete s;
}

proc f4 (bool x) {
    var s = Small(42);
    if x {} else delete s;
}

proc f5() {
    Small x;
    loop {
        delete x;
        x = Small(42);
    }
}

proc f6 {
    var s = Small(42);
    s = Small(33);
}

proc f7(Small s1, copy Small s2, in Small s3, out Small s4, inout Small s5) {
    s4 = Small(1);
}


// R %srcc --ir --target x86_64-unknown-linux %s
program test;

struct Small {
    int x;
    delete { }
};

proc sink(Small) {}
proc sink_int(int) {}

proc f1() {
    var s = Small(42);
    sink(copy s);
    sink(copy s);
    sink(copy Small(42));
    sink(s);
}

proc f2() {
    var s = Small(42);
    sink(copy s);
}

proc f3() {
    int x;
    sink_int(x);
    sink_int(copy x);
    sink_int(copy 42);
}


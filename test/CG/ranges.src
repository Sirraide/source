program test;

proc a (range<int> x) = 3..=4;
proc b (range<int> x) = 3..<4;

proc f1 {
    range<int> a;
    range<int> b = 1..=2;
    var c = 1..=2;
    var d = c.start..=c.end;
}

proc f2 {
    range<int> a;
    range<int> b = 1..<2;
    var c = 1..<2;
    var d = c.start..<c.end;
}

proc f3 -> range<int> {
    var x = 1..=42;
    return x;
}

proc f4 -> range<int> = f3();


// R %srcc --ir --target x86_64-unknown-linux -foverflow-checks=false %s
program test;

proc g extern;

struct Small {
    int x;
    delete { g(); }
};

struct Big {
    int[3] x;
    delete { g(); }
};

proc sink_int(int) {}
proc sink_in(in Small) {}
proc sink_copy(__srcc_by_value__ Small) {}
proc sink_move(Small) {}

proc simple {
    var x = Small(1);
    var x = Big(int[3](2, 3, 4));
}

proc array {
    var x = Small[3](6, 7, 8);
    var x = Big[3](int[3](9, 10, 11), int[3](11, 12, 13), int[3](14, 15, 16));
}

proc optional {
    Small? x;
    Big? x;
    var x = Small?(17);
    var x = Big?(int[3](18, 19, 20));
}

proc temporaries {
    Small(1);
    Small(2).x;
    sink_int(Small(3).x);
    sink_int(Small(5).x + Small(4).x);
    sink_in(Small(6));
    sink_copy(Small(7));
    sink_move(Small(8));
}

simple();
array();
optional();
temporaries();


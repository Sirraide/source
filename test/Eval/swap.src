// V %srcc --eval %s
program test;

struct s {
    int x;
    int y;
}

int a = 1;
int b = 2;
a >< b;
assert a == 2;
assert b == 1;

var s1 = s(3, 4);
var s2 = s(5, 6);
s1 >< s2;
assert s1.x == 5;
assert s1.y == 6;
assert s2.x == 3;
assert s2.y == 4;

s1.x >< s1.y;
assert s1.x == 6;
assert s1.y == 5;

s2.x >< s2.y;
assert s2.x == 4;
assert s2.y == 3;